{
  "name": "mdslides",
  "version": "0.1.0",
  "description": "Turn a Markdown file into a self-contained, themeable HTML slide deck",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mdslides": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "eslint src test"
  },
  "keywords": [
    "markdown",
    "slides",
    "presentation",
    "cli",
    "html"
  ],
  "author": "Charlie Krug",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctkrug/mdslides.git"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "marked": "^12.0.2"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  }
}
